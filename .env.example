# Скопируй в .env.local для локальной разработки
# На Vercel добавь те же переменные в Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://твой-проект.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=твой_publishable_key
SUPABASE_SERVICE_ROLE_KEY=твой_secret_service_role_key

# Сессии (придумай свой секрет)
JWT_SECRET=придумай_длинный_секрет_минимум_32_символа

# Интервал симуляции ESP32 в миллисекундах (7200000 = 2 часа, только локально)
REPORT_INTERVAL_MS=7200000

# Секрет для Vercel Cron (придумай длинную случайную строку)
CRON_SECRET=придумай_длинный_секрет_для_cron