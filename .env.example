# Скопируй в .env.local для локальной разработки
# На Vercel добавь те же переменные в Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://твой-проект.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=твой_publishable_key
SUPABASE_SERVICE_ROLE_KEY=твой_secret_service_role_key

# Сессии (придумай свой секрет)
JWT_SECRET=придумай_длинный_секрет_минимум_32_символа

# Интервал симуляции ESP32 в миллисекундах (3600000 = 1 час, только локально)
REPORT_INTERVAL_MS=3600000

# Секрет для cron (Vercel + Supabase pg_cron — ОДИНАКОВЫЙ!)
CRON_SECRET=придумай_длинный_секрет_для_cron

# После деплоя: Supabase → SQL Editor → запусти supabase/CRON_EVERY_1H.sql
# (подставь тот же CRON_SECRET вместо YOUR_CRON_SECRET)

# Push-уведомления (сгенерируй: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=твой_public_vapid_key
VAPID_PRIVATE_KEY=твой_private_vapid_key
VAPID_SUBJECT=mailto:твой@email.com