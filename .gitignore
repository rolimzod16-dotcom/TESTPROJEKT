# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local sqlite (legacy)
/prisma/dev.db

# temp
.tmp-doc*
.tmp-otchet*
.tmp-otchet.zip

# mobile / apk build
/.tools
/mobile/node_modules
/mobile/android/.gradle
/mobile/android/app/build
/mobile/android/build
/mobile/android/capacitor-cordova-android-plugins/build
/mobile/dist/*.apk

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
